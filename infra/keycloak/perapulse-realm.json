{
  "realm": "perapulse",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "roles": {
    "realm": [
      {
        "name": "STUDENT",
        "description": "Default student role for authenticated users."
      },
      {
        "name": "ALUMNI",
        "description": "Alumni role."
      },
      {
        "name": "ADMIN",
        "description": "Administrator role."
      }
    ]
  },
  "defaultRoles": [
    "default-roles-perapulse",
    "STUDENT"
  ],
  "clients": [
    {
      "clientId": "perapulse-web-test",
      "name": "PeraPulse Web Test Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://perapulse.org/*",
        "https://perapulse.org/*",
        "http://api.perapulse.org/*",
        "https://api.perapulse.org/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://perapulse.org",
        "https://perapulse.org",
        "http://api.perapulse.org",
        "https://api.perapulse.org"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/* http://perapulse.org/* https://perapulse.org/* http://api.perapulse.org/* https://api.perapulse.org/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ]
    },
    {
      "clientId": "perapulse-react-web",
      "name": "PeraPulse React Web Client",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "implicitFlowEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:5173/*",
        "http://perapulse.org/*",
        "https://perapulse.org/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://perapulse.org",
        "https://perapulse.org"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/* http://perapulse.org/* https://perapulse.org/*"
      },
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "sub-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "perapulse-api-test",
      "name": "PeraPulse API Test Client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "student1@eng.pdn.ac.lk",
      "email": "student1@eng.pdn.ac.lk",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Demo",
      "lastName": "Student",
      "credentials": [
        {
          "type": "password",
          "value": "Student123!",
          "temporary": false
        }
      ],
      "realmRoles": [
        "STUDENT"
      ]
    }
  ]
}
